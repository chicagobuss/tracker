# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Postgres (coordination index) ---
PGUSER=coord
PGPASSWORD=changeme
PGDATABASE=coord
PGHOST=127.0.0.1
PGPORT=5432
DATABASE_URL=postgres://coord:changeme@127.0.0.1:5432/coord?sslmode=disable

# --- Content Store (local files or S3) ---
# Set to "file" to store blobs in a local directory, or "s3" to use an S3-compatible store.
STORAGE_TYPE=file

# If STORAGE_TYPE=file:
BLOB_DIR=./data/blobs
BASE_URL=http://127.0.0.1:8080

# If STORAGE_TYPE=s3:
S3_ENDPOINT=192.168.1.100:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=coord-docs
S3_USE_SSL=false

# --- Backup destination (optional; for backup.sh --upload / restore.sh --from-s3) ---
# Any S3-compatible store: AWS S3, or Cloudflare R2
# (BACKUP_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com). Leave blank to
# only ever keep tarballs locally in ./backups.
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=tracker-backups
BACKUP_S3_PREFIX=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# --- API server ---
# Comma-separated; one listener is started per address. Bind only trusted
# interfaces (loopback / LAN / ZeroTier), never 0.0.0.0 with auth disabled.
LISTEN_ADDR=127.0.0.1:8080,192.168.1.100:8080,10.10.10.10:8080
# Comma-separated bearer tokens agents present (Authorization: Bearer <token>).
# Empty = auth DISABLED (dev only — never expose on a network with this empty).
API_TOKENS=
