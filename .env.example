# Copy to .env and adjust. .env is gitignored — never commit real secrets.
#
# The defaults below are enough to run the stack as-is:
#
#   cp .env.example .env && docker compose up -d
#
# Everything is optional except the Postgres password, which you should change.

# --- Postgres (coordination index) ---
# Used by the postgres container AND to build the DATABASE_URL tracker connects
# with. In the default (bridge) compose, tracker reaches Postgres at the
# `postgres` service name — compose sets DATABASE_URL for you, so you don't
# need to define it here.
PGUSER=tracker
PGPASSWORD=changeme
PGDATABASE=tracker

# --- Content store (blobs) ---
# "file" keeps blobs in a local directory (default, zero extra infrastructure).
# "s3" uses any S3-compatible store (AWS S3, Cloudflare R2, MinIO, RustFS).
STORAGE_TYPE=file
BLOB_DIR=./data/blobs

# If STORAGE_TYPE=s3, all four S3_* below are required — tracker refuses to start
# (naming the missing one) rather than silently falling back to local files. The
# bucket is created on startup if it doesn't exist and your credentials allow it.
#   Cloudflare R2:  S3_ENDPOINT=<account-id>.r2.cloudflarestorage.com  + SSL on
#   AWS S3:         S3_ENDPOINT=s3.<region>.amazonaws.com              + SSL on
#   MinIO / RustFS: S3_ENDPOINT=host:9000                              + SSL off on a private net
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=tracker-blobs
# S3_USE_SSL=true

# --- API server ---
# Bearer tokens agents present (Authorization: Bearer <token>), comma-separated.
# EMPTY = AUTH DISABLED. That's fine for a loopback-only dev box, but never
# expose tracker on a network with this empty. Generate one with:
#   openssl rand -hex 32
API_TOKENS=

# Which host interface the published port binds to. 127.0.0.1 (default) keeps
# tracker private to this machine. To let agents on other machines reach it, set
# this to your LAN/Tailscale/ZeroTier IP *and set API_TOKENS above*.
BIND_ADDR=127.0.0.1

# Host port. Change it if something else already owns 8770 (and update BASE_URL).
PORT=8770

# The URL agents use to reach tracker — it's what local blob content URLs are
# built from, so it must match BIND_ADDR/PORT as seen by the agent.
BASE_URL=http://127.0.0.1:8770

# --- Advanced: multiple listeners (host-networking mode only) ---
# The default bridge compose serves 0.0.0.0:8770 inside the container and
# publishes it on BIND_ADDR, so LISTEN_ADDR is unused. It applies only when you
# run with `-f compose.host.yml` (Linux host networking), where tracker binds
# each address itself — one listener per comma-separated address:
# LISTEN_ADDR=127.0.0.1:8770,192.168.1.100:8770,10.10.10.10:8770

# --- Backups (optional) ---
# Any S3-compatible store, for `scripts/backup.sh --upload` / `restore.sh --from-s3`
# (Cloudflare R2: BACKUP_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com).
# Leave blank to only keep tarballs locally in ./backups.
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=tracker-backups
BACKUP_S3_PREFIX=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
